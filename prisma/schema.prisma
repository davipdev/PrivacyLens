datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Empresa {
  id Int @id @default(autoincrement())
  nome String
  codigo String @unique
  createdAt DateTime @default(now())
  usuarios usuario[]
  consultas historicoConsultas[]
}

model usuario {
  id Int @id @default(autoincrement())
  nome String 
  email String   @unique
  senha String 
  role String   @default("user")
  createdAt DateTime @default(now())
  empresaId Int
  empresa Empresa @relation(fields: [empresaId], references: [id])
}

enum NivelRisco {
  baixo
  medio
  alto
  critico
}

model historicoConsultas {
  id Int @id @default(autoincrement())
  urlsite String
  categoria String
  scoresite Int
  nivel NivelRisco
  datahora DateTime @default(now())
  empresaId Int
  empresa Empresa @relation(fields: [empresaId], references: [id])
}